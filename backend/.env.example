# Server — required locally. Railway injects PORT automatically; do not set it there unless you mean to override.
PORT=3001

# Supabase (https://supabase.com/dashboard)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Default org when importing members without an organization column
DEFAULT_ORGANIZATION_ID=

# SendGrid (email outreach)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Public URL of the web app (outreach links: ?token=...)
# In production, set to your Railway HTTPS URL (no trailing slash)
OUTREACH_LINK_BASE_URL=

# Bland (voice agent)
BLAND_API_KEY=
BLAND_WEB_AGENT_ID=
# Optional override (default https://api.bland.ai)
# BLAND_ENDPOINT=

# Twilio (SMS / voice) — optional until used
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
