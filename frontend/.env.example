# Vite loads these at build time (prefix VITE_).
#
# Local dev: copy to `.env.local` and point at your API, e.g. http://localhost:3001
# Production build: defaults are in `.env.production` (deployed API on Railway).
VITE_API_BASE_URL=

# Required: organization UUID used by the dashboard, members, events, outreach, reports.
VITE_ORGANIZATION_ID=

# Bland web agent (voice on /respond)
VITE_BLAND_WEB_AGENT_ID=
