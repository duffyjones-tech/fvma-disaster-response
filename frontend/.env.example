# Vite loads these at build time (prefix VITE_). Copy to .env.local for local dev.

# Leave empty or omit for production builds where the API is served from the same origin.
# For local dev with separate backend, use e.g. http://localhost:3001
VITE_API_BASE_URL=

# Required: organization UUID used by the dashboard, members, events, outreach, reports.
VITE_ORGANIZATION_ID=

# Bland web agent (voice on /respond)
VITE_BLAND_WEB_AGENT_ID=
